---
<main class="page">
  <div class="article-wrap" style="max-width:1100px;">

    <header class="article-header">
      <h1 class="article-header__title">2025 MLB Team Batted Ball Stats</h1>
      <p class="article-header__subtitle">Team-level averages for exit velocity, launch angle, EV90, bat speed, and BABIP, sorted by 2025 win percentage. Click any column header to sort. Toggle between raw numbers and percentile ranks.</p>
    </header>

  </div>

  <div style="padding:0 24px 48px;">

    <style>
      .tbs-controls {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        align-items: center;
        flex-wrap: wrap;
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
      }
      .tbs-controls input[type="text"] {
        background: #2a2522;
        border: 1px solid #3a3530;
        border-radius: 6px;
        color: #e8e2da;
        font-size: 0.85rem;
        padding: 7px 12px;
        width: 200px;
        outline: none;
      }
      .tbs-controls input[type="text"]:focus { border-color: #c96442; }
      .tbs-controls input[type="text"]::placeholder { color: #5a5450; }

      .tbs-legend {
        font-size: 0.75rem;
        color: #6a6460;
        margin-left: auto;
      }

      .tbs-toggle-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        color: #8a8278;
      }
      .tbs-toggle-wrap span.active { color: #e8e2da; font-weight: 600; }
      .tbs-toggle {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
      }
      .tbs-toggle input { opacity: 0; width: 0; height: 0; }
      .tbs-toggle-track {
        position: absolute;
        inset: 0;
        background: #3a3530;
        border-radius: 12px;
        cursor: pointer;
        transition: background 0.2s;
      }
      .tbs-toggle input:checked + .tbs-toggle-track { background: #c96442; }
      .tbs-toggle-thumb {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        background: #e8e2da;
        border-radius: 50%;
        transition: transform 0.2s;
        pointer-events: none;
      }
      .tbs-toggle input:checked ~ .tbs-toggle-thumb { transform: translateX(20px); }

      .tbs-wrap {
        max-width: 1100px;
        margin: 0 auto;
        overflow-x: auto;
      }

      .tbs-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        background: transparent;
      }

      .tbs-table thead th {
        background: #211e1b;
        color: #a09890;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 10px 14px;
        text-align: right;
        cursor: pointer;
        user-select: none;
        white-space: nowrap;
        border-bottom: 2px solid #3a3530;
        position: sticky;
        top: 0;
        z-index: 1;
      }
      .tbs-table thead th:first-child,
      .tbs-table thead th:last-child { text-align: left; }
      .tbs-table thead th:hover { color: #e8e2da; }
      .tbs-table thead th.sorted-asc::after  { content: " ↑"; color: #c96442; }
      .tbs-table thead th.sorted-desc::after { content: " ↓"; color: #c96442; }

      .tbs-table tbody tr {
        border-bottom: 1px solid #2a2522;
        transition: background 0.1s;
      }
      .tbs-table tbody tr:hover { background: #221f1c; }
      .tbs-table tbody tr.quintile-break td {
        border-bottom: 2px dotted #5a5048;
      }

      .tbs-table td {
        padding: 10px 14px;
        text-align: right;
        vertical-align: top;
        color: #e8e2da;
      }
      .tbs-table td:first-child { text-align: left; }
      .tbs-table td:last-child  { text-align: left; min-width: 260px; max-width: 380px; color: #a09080; font-size: 0.8rem; line-height: 1.5; }

      .tbs-team { font-weight: 700; color: #f0ebe3; letter-spacing: 0.03em; }
      .tbs-pct  { color: #c8bfb0; }

      .tbs-q5 { color: #7ec98a; }
      .tbs-q4 { color: #b8d98a; }
      .tbs-q3 { color: #e8e2da; }
      .tbs-q2 { color: #e0a060; }
      .tbs-q1 { color: #e07060; }

      .tbs-badge {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 1px 6px;
        border-radius: 3px;
        margin-right: 4px;
        vertical-align: middle;
        letter-spacing: 0.03em;
      }
      .tbs-badge-green  { background: #1e3a22; color: #7ec98a; }
      .tbs-badge-red    { background: #3a1e1a; color: #e07060; }
      .tbs-badge-orange { background: #3a2a18; color: #d4914a; }
      .tbs-badge-blue   { background: #1a2a3a; color: #5aabde; }

      .tbs-source {
        max-width: 1100px;
        margin: 16px auto 0;
        font-size: 0.75rem;
        color: #5a5450;
      }
    </style>

    <div class="tbs-controls">
      <input type="text" id="tbs-search" placeholder="Filter teams..." />
      <div class="tbs-toggle-wrap">
        <span id="tbs-lbl-raw" class="active">Raw</span>
        <label class="tbs-toggle">
          <input type="checkbox" id="tbs-pctile-toggle" />
          <div class="tbs-toggle-track"></div>
          <div class="tbs-toggle-thumb"></div>
        </label>
        <span id="tbs-lbl-pct">Percentile</span>
      </div>
      <span class="tbs-legend">EV = Exit Velocity &nbsp;|&nbsp; LA = Launch Angle &nbsp;|&nbsp; EV90 = 90th-percentile EV &nbsp;|&nbsp; BatSpd = Bat Speed &nbsp;|&nbsp; BABIP</span>
    </div>

    <div class="tbs-wrap">
      <table class="tbs-table" id="tbs-main-table">
        <thead>
          <tr>
            <th data-col="0" data-type="str">Team</th>
            <th data-col="1" data-type="num">PCT</th>
            <th data-col="2" data-type="num"><span class="term" data-term="exit velocity">EV</span></th>
            <th data-col="3" data-type="num"><span class="term" data-term="launch angle">LA</span></th>
            <th data-col="4" data-type="num"><span class="term" data-term="ev90">EV90</span></th>
            <th data-col="5" data-type="num"><span class="term" data-term="bat speed">BatSpd</span></th>
            <th data-col="6" data-type="num"><span class="term" data-term="babip (batter)">BABIP</span></th>
            <th data-col="7" data-type="str">Notes</th>
          </tr>
        </thead>
        <tbody id="tbs-tbody"></tbody>
      </table>
    </div>

    <p class="tbs-source">Source: FanGraphs player-level batted ball data, 2025 regular season. Averages computed across all qualified players per team. Win percentages from 2025 MLB final standings.</p>

  </div>
</main>

<script>
(function () {
  const g = s => s.replace(/badge /g, 'tbs-badge ').replace(/badge-/g, 'tbs-badge-');

  const data = [
    ["MIL", .599, 88.49, 11.47, 103.88, 71.50, .310, g(`<span class="badge badge-green">BABIP #1</span> Led MLB in BABIP (.310) despite below-average EV and bat speed. Their offense ran on contact placement, not raw power, and it was good enough to win the NL.`)],
    ["PHI", .593, 89.55, 12.24, 104.49, 71.74, .293, g(`<span class="badge badge-green">Balanced</span> Solid across every metric in 2025. One of the most well-rounded offensive profiles in baseball.`)],
    ["TOR", .580, 88.77, 15.11, 104.15, 71.27, .299, g(`<span class="badge badge-blue">Fly Ball</span> A high launch angle (15.11) reflected an aggressive pull-and-lift approach. Below-average EV capped the ceiling, but it was enough for 94 wins.`)],
    ["NYY", .580, 90.71, 14.65, 105.72, 72.77, .287, g(`<span class="badge badge-green">EV #1</span><span class="badge badge-green">EV90 #1</span> Led MLB in exit velocity, EV90, and bat speed in 2025. As elite a raw power profile as any lineup produced all season.`)],
    ["LAD", .574, 89.98, 15.05, 104.36, 71.13, .294, g(`<span class="badge badge-blue">Fly Ball</span> A high launch angle (15.05) paired with strong EV. A classic Dodger power-first lineup. Below-average bat speed was the one surprise.`)],
    ["CHC", .568, 88.61, 14.16, 103.84, 70.93, .284, g(`<span class="badge badge-orange">Fly Ball</span> High launch angle without the bat speed or EV to match. The Cubs relied on pull power rather than overall contact quality, and still won 92 games.`)],
    ["SDP", .556, 88.09, 11.41, 103.33, 70.96, .295, g(`<span class="badge badge-blue">Line Drive</span> The lowest EV90 in MLB (103.33) and a flat launch angle. A contact-first, gap-hitting approach with limited power upside. Ninety wins showed it worked.`)],
    ["SEA", .556, 89.34, 12.37, 104.32, 71.32, .295, g(`<span class="badge badge-green">Balanced</span> Quietly above-average in EV and EV90 with a balanced launch angle. An understated offensive profile that matched San Diego win-for-win.`)],
    ["BOS", .549, 89.61, 11.56, 104.80, 72.50, .304, g(`<span class="badge badge-green">Hard Contact</span> Strong EV and bat speed with a low launch angle. A line-drive power team that didn't need loft to do damage. The BABIP of .304 reflected consistent hard contact.`)],
    ["CLE", .543, 88.96, 16.16, 104.15, 71.85, .259, g(`<span class="badge badge-red">BABIP #29</span><span class="badge badge-blue">LA #1</span> The highest launch angle in MLB (16.16) but the second-lowest BABIP. A lot of fly balls didn't land. Cleveland won 88 games in spite of the contact profile, not because of it.`)],
    ["HOU", .537, 88.65, 13.72, 104.79, 72.23, .301, g(`<span class="badge badge-green">Deep EV</span> Strong EV90 (104.79) and bat speed with a neutral launch angle. Contact quality held up deep into the lineup and powered an 87-win season.`)],
    ["DET", .537, 89.28, 16.15, 104.35, 71.60, .287, g(`<span class="badge badge-blue">Fly Ball</span> The second-highest launch angle (16.15) with good EV to back it up. Unlike Cleveland, Detroit's fly-ball approach converted. Eighty-seven wins in a breakout year.`)],
    ["NYM", .512, 90.27, 11.90, 105.66, 72.34, .289, g(`<span class="badge badge-green">EV #2</span><span class="badge badge-green">EV90 #2</span> Second in both EV and EV90 despite finishing at .512. The Mets had one of the most underleveraged power profiles in baseball. The production didn't match the contact quality.`)],
    ["CIN", .512, 89.09, 13.28, 103.85, 70.94, .277, g(`<span class="badge badge-orange">Below Avg</span> Near-average EV with below-average bat speed and EV90. A balanced but unexceptional profile that landed them exactly at .512.`)],
    ["KCR", .506, 89.50, 14.35, 104.41, 71.88, .270, g(`<span class="badge badge-orange">Low BABIP</span> Above-average EV and bat speed, but a BABIP of .270 suggests fly balls weren't converting. A pull-heavy approach likely cost them some hits.`)],
    ["SFG", .500, 88.11, 13.27, 103.59, 71.10, .279, g(`<span class="badge badge-red">EV90 #29</span> The second-lowest EV90 in baseball. Soft contact ran deep in the roster, and the Giants finished exactly .500. A result that felt generous given the underlying numbers.`)],
    ["TEX", .500, 88.54, 14.59, 104.16, 70.96, .274, g(`<span class="badge badge-orange">Fly Ball</span> A high launch angle (14.59) without the EV or bat speed to carry it. Texas finished .500 despite a fly-ball approach that didn't have the tools behind it.`)],
    ["ARI", .494, 88.85, 11.40, 103.96, 71.18, .289, g(`<span class="badge badge-blue">Line Drive</span> The second-lowest launch angle (11.40). A contact-first approach with limited over-the-fence upside. The Diamondbacks just missed .500 in a season that felt like a step back.`)],
    ["MIA", .488, 89.39, 11.83, 104.39, 71.25, .298, g(`<span class="badge badge-blue">Line Drive</span> A low launch angle (11.83) with above-average EV. The Marlins made solid contact but couldn't string enough of it together to get over .500.`)],
    ["STL", .481, 89.27, 14.24, 104.25, 71.79, .294, g(`<span class="badge badge-orange">Stranded Power</span> Above-average in most categories, yet finished under .500. The contact metrics suggested a better offense than St. Louis got out of it in 2025.`)],
    ["TBR", .475, 89.27, 10.90, 104.83, 72.40, .305, g(`<span class="badge badge-blue">Low LA</span><span class="badge badge-green">BABIP #2</span> The second-lowest launch angle in MLB (10.90). An extreme groundball and line-drive team. The BABIP of .305 rewarded the approach, but strong EV90 and bat speed were left on the table.`)],
    ["ATH", .469, 88.50, 12.76, 104.47, 71.71, .298, g(`<span class="badge badge-orange">Average</span> Quietly above-average bat speed and EV90, but a mid-range profile that didn't translate to wins in 2025.`)],
    ["ATL", .469, 89.48, 14.42, 105.21, 71.76, .291, g(`<span class="badge badge-red">Underperformer</span> Strong EV90 (105.21, 4th in MLB) and above-average EV. The Braves had the contact profile of a contender and finished 76-86. A significant underperformance.`)],
    ["BAL", .463, 89.30, 13.82, 104.94, 72.44, .274, g(`<span class="badge badge-red">Underperformer</span> Above-average EV90 (104.94) and elite bat speed (72.44, 3rd in MLB), yet finished 75-87 with a BABIP of .274. The underlying metrics were much better than the results.`)],
    ["LAA", .444, 88.69, 13.85, 104.34, 71.39, .274, g(`<span class="badge badge-orange">Average</span> Unexceptional across the board with a below-average BABIP. No standout strengths, and 72 wins reflected it.`)],
    ["PIT", .438, 89.31, 12.24, 105.36, 72.77, .275, g(`<span class="badge badge-red">Talent Gap</span><span class="badge badge-green">EV90 #3</span> The third-highest EV90 and tied for the top bat speed in baseball, yet Pittsburgh won just 71 games. The gap between contact quality and results was the most glaring on the board.`)],
    ["MIN", .432, 88.78, 14.00, 104.08, 70.85, .258, g(`<span class="badge badge-red">BatSpd #30</span><span class="badge badge-red">BABIP #30</span> Dead last in bat speed and BABIP. A fly-ball approach (launch angle 14.00) without the contact quality to support it. A tough combination that produced 70 wins.`)],
    ["WSN", .407, 88.91,  9.61, 104.82, 71.41, .293, g(`<span class="badge badge-blue">LA #30</span> The lowest launch angle in MLB by a wide margin (9.61). An extreme groundball team. Solid EV90 (104.82) went largely to waste on balls in the dirt. Sixty-six wins.`)],
    ["CHW", .370, 89.39, 15.21, 104.08, 70.83, .264, g(`<span class="badge badge-red">LA #3</span><span class="badge badge-red">Low BABIP</span> The third-highest launch angle (15.21) with the second-lowest bat speed and a BABIP of .264. Lots of weak fly balls. About as difficult a combination as you can have. Sixty wins.`)],
    ["COL", .265, 88.08, 13.65, 103.98, 71.56, .297, g(`<span class="badge badge-red">EV #30</span><span class="badge badge-red">EV90 #30</span> The worst EV and EV90 in baseball in 2025. The near-league-average BABIP (.297) was a Coors Field mirage. Nothing to build on offensively, and 43 wins showed it.`)],
  ];

  const statCols = [2, 3, 4, 5, 6];
  const pctileMap = {};
  statCols.forEach(col => {
    const sorted = [...data].sort((a, b) => a[col] - b[col]);
    sorted.forEach((row, rank) => {
      const team = row[0];
      if (!pctileMap[team]) pctileMap[team] = {};
      pctileMap[team][col] = Math.round((rank / (data.length - 1)) * 100);
    });
  });

  let sortCol = 1, sortDir = -1, showPctile = false;

  function qClass(p) {
    if (p >= 80) return 'tbs-q5';
    if (p >= 60) return 'tbs-q4';
    if (p >= 40) return 'tbs-q3';
    if (p >= 20) return 'tbs-q2';
    return 'tbs-q1';
  }

  function fmt(val, col, team) {
    if (col === 0) return `<span class="tbs-team">${val}</span>`;
    if (col === 1) return `<span class="tbs-pct">${val.toFixed(3).replace('0.', '.')}</span>`;
    if (col === 7) return val;
    if (showPctile && statCols.includes(col)) {
      const p = pctileMap[team][col];
      return `<span class="${qClass(p)}">${p}</span>`;
    }
    if (col === 6) return val.toFixed(3).replace('0.', '.');
    return val.toFixed(2);
  }

  // Precompute min/max for each stat col across full dataset so colors are stable during filtering
  const statRanges = {};
  statCols.forEach(col => {
    const vals = data.map(r => r[col]);
    statRanges[col] = { min: Math.min(...vals), max: Math.max(...vals) };
  });

  function colorClass(col, val) {
    if (col < 2 || col > 6) return '';
    if (col === 3) return ''; // LA: no color
    const { min, max } = statRanges[col];
    const p = (val - min) / (max - min) * 100;
    return qClass(p);
  }

  function render(rows) {
    const tbody = document.getElementById('tbs-tbody');
    const qSize = Math.ceil(rows.length / 5);
    tbody.innerHTML = rows.map((row, idx) => {
      const tds = row.map((val, i) => {
        const cls = showPctile && statCols.includes(i) ? '' : colorClass(i, val);
        return `<td class="${cls}">${fmt(val, i, row[0])}</td>`;
      });
      const brk = (idx + 1) % qSize === 0 && idx + 1 < rows.length ? 'quintile-break' : '';
      return `<tr class="${brk}">${tds.join('')}</tr>`;
    }).join('');
  }

  function applyAll() {
    const q = document.getElementById('tbs-search').value.toLowerCase();
    let rows = data.filter(r => r[0].toLowerCase().includes(q));
    rows.sort((a, b) => {
      const av = a[sortCol], bv = b[sortCol];
      if (typeof av === 'string') return sortDir * av.localeCompare(bv);
      return sortDir * (av - bv);
    });
    render(rows);
    document.querySelectorAll('.tbs-table thead th').forEach(th => th.classList.remove('sorted-asc', 'sorted-desc'));
    const th = document.querySelector(`.tbs-table thead th[data-col="${sortCol}"]`);
    if (th) th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
  }

  document.querySelectorAll('.tbs-table thead th').forEach(th => {
    th.addEventListener('click', (e) => {
      if (e.target.closest('.term')) return; // let glossary handle it, don't sort
      const col = +th.dataset.col;
      if (sortCol === col) { sortDir *= -1; } else { sortCol = col; sortDir = th.dataset.type === 'str' ? 1 : -1; }
      applyAll();
    });
  });

  document.getElementById('tbs-search').addEventListener('input', applyAll);

  document.getElementById('tbs-pctile-toggle').addEventListener('change', function () {
    showPctile = this.checked;
    document.getElementById('tbs-lbl-raw').classList.toggle('active', !showPctile);
    document.getElementById('tbs-lbl-pct').classList.toggle('active', showPctile);
    applyAll();
  });

  applyAll();
})();
</script>
<script src="/js/glossary.js"></script>
