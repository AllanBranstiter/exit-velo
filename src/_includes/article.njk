{% extends "base.njk" %}
{% block content %}
  <main class="page" id="main-content">
    <div class="article-wrap">

      <header class="article-header">
        <div class="article-header__meta">
          <span class="article-header__category">{{ category }}</span>
          {% if level %}<span class="article-header__level article-header__level--{{ level | lower }}">{{ level }}</span>{% endif %}
          <time class="article-header__date" datetime="{{ date | dateYearMonth }}">{{ date | dateDisplay }}</time>
        </div>
        <h1 class="article-header__title">{{ title }}</h1>
        {% if subtitle %}<p class="article-header__subtitle">{{ subtitle }}</p>{% endif %}
        <p class="article-header__byline">By {{ author if author else "Exit Velo" }}</p>
      </header>

      <p class="glossary-hint">Tap or click any <span class="term" data-term="statcast" style="pointer-events:none; border-bottom: 1px dotted #e05c1a;">underlined term</span> to see its definition.</p>

      <article class="article-body">
        {{ content | safe }}
      </article>

    </div>

    {% if related and related.length > 0 %}
    <aside class="related-articles" aria-label="Related articles">
      <h2 class="related-articles__heading">More to read</h2>
      <ul class="related-articles__list">
        {% for item in related %}
        <li class="article-card">
          <div class="article-card__meta">
            <a href="/category/{{ item.frontmatter.category | categorySlug }}" class="article-card__category">{{ item.frontmatter.category }}</a>
            {% if item.frontmatter.level %}<span class="article-header__level article-header__level--{{ item.frontmatter.level | lower }}">{{ item.frontmatter.level }}</span>{% endif %}
            <time datetime="{{ item.frontmatter.date | dateYearMonth }}">{{ item.frontmatter.date | dateDisplay }}</time>
          </div>
          <h3 class="article-card__title">
            <a href="{{ item.url }}">{{ item.frontmatter.title }}</a>
          </h3>
          <p class="article-card__excerpt">{{ item.frontmatter.description }}</p>
          <a href="{{ item.url }}" class="article-card__readmore">Read article &rarr;</a>
        </li>
        {% endfor %}
      </ul>
    </aside>
    {% endif %}

  </main>

  <script src="/js/glossary.js"></script>

  <style>
  .disclosure-arrow {
    display: inline-block;
    transition: transform 0.5s ease;
  }
  details[open] > summary .disclosure-arrow {
    transform: rotate(90deg);
  }
  details .disclosure-content {
    overflow: hidden;
  }
  details summary { list-style: none; }
  details summary::-webkit-details-marker { display: none; }
  </style>

  <script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('details').forEach(function (detail) {
      var content = detail.querySelector('.disclosure-content');
      if (!content) return;
      var summary = detail.querySelector('summary');

      summary.addEventListener('click', function (e) {
        e.preventDefault();
        if (detail.open) {
          content.style.transition = 'max-height 0.7s ease, opacity 0.5s ease';
          content.style.maxHeight = content.scrollHeight + 'px';
          content.offsetHeight;
          content.style.opacity = '0';
          content.style.maxHeight = '0';
          content.addEventListener('transitionend', function handler() {
            detail.open = false;
            content.removeEventListener('transitionend', handler);
            content.style.transition = '';
            content.style.maxHeight = '';
            content.style.opacity = '';
          });
        } else {
          detail.open = true;
          var h = content.scrollHeight;
          content.style.maxHeight = '0';
          content.style.opacity = '0';
          content.style.overflow = 'hidden';
          content.offsetHeight;
          content.style.transition = 'max-height 0.7s ease, opacity 0.5s ease';
          content.style.maxHeight = h + 'px';
          content.style.opacity = '1';
          content.addEventListener('transitionend', function handler() {
            content.removeEventListener('transitionend', handler);
            content.style.transition = '';
            content.style.maxHeight = '';
            content.style.overflow = '';
          });
        }
      });
    });
  });
  </script>

  <!-- Structured data: Article -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | json }},
    "description": {{ description | json }},
    "datePublished": {{ date | dateIso | json }},
    "dateModified": {{ date | dateIso | json }},
    "author": {
      "@type": "Person",
      "name": {{ author | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": "Exit Velo",
      "url": "https://exitvelo.us",
      "logo": {
        "@type": "ImageObject",
        "url": "https://exitvelo.us/images/favicon.svg"
      }
    },
    "url": {{ ("https://exitvelo.us" + url) | json }},
    "image": {{ ("https://exitvelo.us" + (image if image else (article_image if article_image else "/images/og-default.png"))) | json }},
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ ("https://exitvelo.us" + url) | json }}
    }{% if category %},
    "articleSection": {{ category | json }}{% endif %}{% if keywords %},
    "keywords": {{ keywords | json }}{% endif %}
  }
  </script>

  {% if category and categorySlug %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://exitvelo.us/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ category | json }},
        "item": {{ ("https://exitvelo.us/category/" + categorySlug) | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ title | json }}
      }
    ]
  }
  </script>
  {% endif %}
{% endblock %}
