{% extends "base.njk" %}
{% block content %}
  <main class="page" id="main-content">
    <div class="article-wrap">

      <header class="article-header">
        <div class="article-header__meta">
          <span class="article-header__category">{{ category }}</span>
          {% if level %}<span class="article-header__level article-header__level--{{ level | lower }}">{{ level }}</span>{% endif %}
          <time class="article-header__date" datetime="{{ date | dateYearMonth }}">{{ date | dateDisplay }}</time>
        </div>
        <h1 class="article-header__title">{{ title }}</h1>
        {% if subtitle %}<p class="article-header__subtitle">{{ subtitle }}</p>{% endif %}
        <p class="article-header__byline">By {{ author if author else "Exit Velo" }}</p>
      </header>

      <p class="glossary-hint">Tap or click any <span class="term" data-term="statcast" style="pointer-events:none; border-bottom: 1px dotted #e05c1a;">underlined term</span> to see its definition.</p>

      <article class="article-body">
        {{ content | safe }}
      </article>

    </div>
  </main>

  <script src="/js/glossary.js"></script>

  <style>
  .disclosure-arrow {
    display: inline-block;
    transition: transform 0.5s ease;
  }
  details[open] > summary .disclosure-arrow {
    transform: rotate(90deg);
  }
  details .disclosure-content {
    overflow: hidden;
  }
  details summary { list-style: none; }
  details summary::-webkit-details-marker { display: none; }
  </style>

  <script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('details').forEach(function (detail) {
      var content = detail.querySelector('.disclosure-content');
      if (!content) return;
      var summary = detail.querySelector('summary');

      summary.addEventListener('click', function (e) {
        e.preventDefault();
        if (detail.open) {
          content.style.transition = 'max-height 0.7s ease, opacity 0.5s ease';
          content.style.maxHeight = content.scrollHeight + 'px';
          content.offsetHeight;
          content.style.opacity = '0';
          content.style.maxHeight = '0';
          content.addEventListener('transitionend', function handler() {
            detail.open = false;
            content.removeEventListener('transitionend', handler);
            content.style.transition = '';
            content.style.maxHeight = '';
            content.style.opacity = '';
          });
        } else {
          detail.open = true;
          var h = content.scrollHeight;
          content.style.maxHeight = '0';
          content.style.opacity = '0';
          content.style.overflow = 'hidden';
          content.offsetHeight;
          content.style.transition = 'max-height 0.7s ease, opacity 0.5s ease';
          content.style.maxHeight = h + 'px';
          content.style.opacity = '1';
          content.addEventListener('transitionend', function handler() {
            content.removeEventListener('transitionend', handler);
            content.style.transition = '';
            content.style.maxHeight = '';
            content.style.overflow = '';
          });
        }
      });
    });
  });
  </script>

  <!-- Structured data: Article -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | json }},
    "description": {{ description | json }},
    "datePublished": {{ date | dateIso | json }},
    "dateModified": {{ date | dateIso | json }},
    "author": {
      "@type": "Person",
      "name": {{ author | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": "Exit Velo",
      "url": "https://exitvelo.us",
      "logo": {
        "@type": "ImageObject",
        "url": "https://exitvelo.us/images/favicon.svg"
      }
    },
    "url": {{ ("https://exitvelo.us" + url) | json }},
    "image": {{ ("https://exitvelo.us" + (image if image else "/images/og-default.png")) | json }},
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ ("https://exitvelo.us" + url) | json }}
    }{% if category %},
    "articleSection": {{ category | json }}{% endif %}{% if keywords %},
    "keywords": {{ keywords | json }}{% endif %}
  }
  </script>
{% endblock %}
