<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if title %} — {% endif %}Exit Velo</title>
  <meta name="description" content="{{ description if description else 'Cincinnati Reds baseball by the numbers.' }}">
  {% if keywords %}<meta name="keywords" content="{{ keywords | join(', ') }}">{% endif %}

  <!-- Canonical URL -->
  <link rel="canonical" href="https://exitvelo.us{{ url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="Exit Velo">
  <meta property="og:title" content="{{ title if title else 'Exit Velo' }}">
  <meta property="og:description" content="{{ description if description else 'Cincinnati Reds baseball by the numbers.' }}">
  <meta property="og:url" content="https://exitvelo.us{{ url }}">
  <meta property="og:image" content="https://exitvelo.us{{ image if image else (article_image if article_image else '/images/og-default.png') }}">
  <meta property="og:image:alt" content="{{ image_alt if image_alt else (article_image_alt if article_image_alt else 'Exit Velo — Cincinnati Reds baseball by the numbers') }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {% if date %}
  <meta property="og:type" content="article">
  <meta property="article:published_time" content="{{ date | dateIso }}">
  {% if author %}<meta property="article:author" content="{{ author }}">{% endif %}
  {% if category %}<meta property="article:section" content="{{ category }}">{% endif %}
  {% else %}
  <meta property="og:type" content="website">
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title if title else 'Exit Velo' }}">
  <meta name="twitter:description" content="{{ description if description else 'Cincinnati Reds baseball by the numbers.' }}">
  <meta name="twitter:image" content="https://exitvelo.us{{ image if image else (article_image if article_image else '/images/og-default.png') }}">
  <meta name="twitter:image:alt" content="{{ image_alt if image_alt else (article_image_alt if article_image_alt else 'Exit Velo — Cincinnati Reds baseball by the numbers') }}">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link rel="alternate" type="application/rss+xml" title="Exit Velo" href="https://exitvelo.us/feed.xml">

  <!-- Structured data: WebSite -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Exit Velo",
    "url": "https://exitvelo.us",
    "description": "Cincinnati Reds baseball by the numbers.",
    "publisher": {
      "@type": "Organization",
      "name": "Exit Velo",
      "url": "https://exitvelo.us",
      "logo": {
        "@type": "ImageObject",
        "url": "https://exitvelo.us/images/favicon.svg"
      }
    }
  }
  </script>

  <script defer src="https://exit-velo-umami.fly.dev/script.js" data-website-id="4924bccb-22b0-4f87-98b2-d6056b8d8dc7"></script>
</head>
<body>

  <a href="#main-content" class="skip-link">Skip to content</a>

  <nav class="nav" aria-label="Main navigation">
    <div class="nav__inner">
      <a href="/" class="nav__logo">Exit<span>Velo</span></a>
      <p class="nav__tagline">Cincinnati Reds baseball by the numbers.</p>
      <ul class="nav__links">
        <li><a href="/heat-check/CIN_heat_check.html">Heat Check</a></li>
        <li class="nav__dropdown">
          <button class="nav__dropdown-toggle" aria-expanded="false" aria-haspopup="true">Categories</button>
          <ul class="nav__dropdown-menu" role="menu">
            <li role="menuitem"><a href="/category/player-profile">Player Profile</a></li>
            <li role="menuitem"><a href="/category/stat-explainer">Stat Explainer</a></li>
            <li role="menuitem"><a href="/category/fantasy-baseball">Fantasy Baseball</a></li>
            <li role="menuitem"><a href="/category/farm-system">Farm System</a></li>
            <li role="menuitem"><a href="/category/team-analysis">Team Analysis</a></li>
            <li role="menuitem"><a href="/category/rankings">Rankings</a></li>
          </ul>
        </li>
        <li><a href="/about.html">About</a></li>
      </ul>
    </div>
  </nav>

  {% block content %}{{ content | safe }}{% endblock %}

  <footer class="footer">
    <p>&copy; 2026 Allan Branstiter. All rights reserved.</p>
  </footer>

  <script>
  (function() {
    var toggle = document.querySelector('.nav__dropdown-toggle');
    var menu = document.querySelector('.nav__dropdown-menu');
    if (!toggle || !menu) return;
    toggle.addEventListener('click', function() {
      var open = menu.hasAttribute('data-open');
      if (open) { menu.removeAttribute('data-open'); toggle.setAttribute('aria-expanded', 'false'); }
      else       { menu.setAttribute('data-open', ''); toggle.setAttribute('aria-expanded', 'true'); }
    });
    document.addEventListener('click', function(e) {
      if (!toggle.contains(e.target) && !menu.contains(e.target)) {
        menu.removeAttribute('data-open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  })();
  </script>

</body>
</html>
