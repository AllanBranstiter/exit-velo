{% extends "base.njk" %}
{% block content %}
  <main class="page">

    <header class="home-header">
      <h1 class="home-header__title">Exit Velo</h1>
      <p class="home-header__description">Advanced stats. Beginner friendly.</p>
    </header>

    <ul class="article-list">

      {% for article in articles %}
      <li class="article-card">
        <div class="article-card__meta">
          <span class="article-card__category">{{ article.frontmatter.category }}</span>
          {% if article.frontmatter.level %}<span class="article-header__level article-header__level--{{ article.frontmatter.level | lower }}">{{ article.frontmatter.level }}</span>{% endif %}
          <time datetime="{{ article.frontmatter.date | dateYearMonth }}">{{ article.frontmatter.date | dateDisplay }}</time>
        </div>
        <h2 class="article-card__title">
          <a href="{{ article.url }}">{{ article.frontmatter.title }}</a>
        </h2>
        <p class="article-card__excerpt">{{ article.frontmatter.description }}</p>
        <a href="{{ article.url }}" class="article-card__readmore">Read article &rarr;</a>
      </li>
      {% endfor %}

    </ul>

  </main>
{% endblock %}
