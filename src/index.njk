{% extends "base.njk" %}
{% block content %}
  <main class="page" id="main-content">

    <header class="home-header">
      <h1 class="home-header__title">Exit Velo</h1>
      <p class="home-header__description">Cincinnati Reds baseball by the numbers.</p>
    </header>

    {% set featured = featuredArticles %}

    {% if featured.length > 0 %}
    <div class="home-hero-row">
      <section class="home-hero" aria-label="Latest article">
        <a href="{{ featured[0].url }}" class="home-hero__link">
          {% set heroImg = featured[0].frontmatter.image or featured[0].frontmatter.article_image %}
          {% set heroAlt = featured[0].frontmatter.image_alt or featured[0].frontmatter.article_image_alt or featured[0].frontmatter.title %}
          <picture>
            <source srcset="{{ heroImg | webpName }}" type="image/webp">
            <img src="{{ heroImg }}" alt="{{ heroAlt }}" class="home-hero__image" loading="eager" fetchpriority="high" decoding="async">
          </picture>
        </a>
        <div class="home-hero__body">
          <div class="home-hero__meta">
            <a href="/category/{{ featured[0].frontmatter.category | categorySlug }}" class="article-card__category">{{ featured[0].frontmatter.category }}</a>
            {% if featured[0].frontmatter.level %}<span class="article-header__level article-header__level--{{ featured[0].frontmatter.level | lower }}">{{ featured[0].frontmatter.level }}</span>{% endif %}
            <time datetime="{{ featured[0].frontmatter.date | dateYearMonth }}">{{ featured[0].frontmatter.date | dateDisplay }}</time>
          </div>
          <h2 class="home-hero__title">
            <a href="{{ featured[0].url }}">{{ featured[0].frontmatter.title }}</a>
          </h2>
          {% if featured[0].frontmatter.subtitle %}<p class="home-hero__subtitle">{{ featured[0].frontmatter.subtitle }}</p>{% endif %}
        </div>
      </section>

      <aside class="home-sidebar">
        <div class="sidebar-widget">
          <h3 class="sidebar-widget__label">NL Central</h3>
          {% if standings.length > 0 %}
          <table class="sidebar-standings">
            <thead>
              <tr><th>Team</th><th>W</th><th>L</th><th>GB</th></tr>
            </thead>
            <tbody>
              {% for team in standings %}
              <tr{% if team.isReds %} class="sidebar-standings__reds"{% endif %}>
                <td>{{ team.name }}</td>
                <td>{{ team.wins }}</td>
                <td>{{ team.losses }}</td>
                <td>{{ team.gamesBack }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
          {% else %}
          <p class="sidebar-widget__empty">Standings unavailable</p>
          {% endif %}
        </div>

        <div class="sidebar-widget sidebar-widget--scrollable">
          <h3 class="sidebar-widget__label">Breaking News</h3>
          {% if redsNews.length > 0 %}
          <ul class="sidebar-news">
            {% for item in redsNews %}
            <li class="sidebar-news__item">
              <a href="{{ item.link }}" class="sidebar-news__link" target="_blank" rel="noopener">
                <p class="sidebar-news__text">{{ item.description }}</p>
                <time class="sidebar-news__date" datetime="{{ item.date }}">{{ item.date | dateDisplay }}</time>
              </a>
            </li>
            {% endfor %}
          </ul>
          {% else %}
          <p class="sidebar-widget__empty">No recent news</p>
          {% endif %}
        </div>
      </aside>
    </div>
    {% endif %}

    {% if featured.length > 3 %}
    <section class="home-trending" aria-label="Recent articles">
      <h2 class="home-trending__label">Recent Articles</h2>
      <div class="home-trending__grid">
        {% for i in [1, 2, 3] %}
        {% if featured[i] %}
        <a href="{{ featured[i].url }}" class="home-trending__card">
          {% set cardImg = featured[i].frontmatter.image or featured[i].frontmatter.article_image %}
          {% set cardAlt = featured[i].frontmatter.image_alt or featured[i].frontmatter.article_image_alt or featured[i].frontmatter.title %}
          <picture>
            <source srcset="{{ cardImg | webpName }}" type="image/webp">
            <img src="{{ cardImg }}" alt="{{ cardAlt }}" class="home-trending__image" loading="lazy" decoding="async">
          </picture>
          <h3 class="home-trending__title">{{ featured[i].frontmatter.title }}</h3>
          <p class="home-trending__description">{{ featured[i].frontmatter.description }}</p>
          <div class="home-trending__meta">
            <a href="/category/{{ featured[i].frontmatter.category | categorySlug }}" class="article-card__category">{{ featured[i].frontmatter.category }}</a>
            <time datetime="{{ featured[i].frontmatter.date | dateYearMonth }}">{{ featured[i].frontmatter.date | dateDisplay }}</time>
          </div>
        </a>
        {% endif %}
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <section class="search-filters" aria-label="Filter articles">
      <div class="search-filters__search">
        <input
          type="search"
          id="article-search"
          class="search-filters__input"
          placeholder="Search articles..."
          autocomplete="off"
          aria-label="Search articles by title, description, or keyword"
        >
      </div>

      <div class="search-filters__group">
        <span class="search-filters__label">Category</span>
        <div class="search-filters__pills" id="category-pills" role="group" aria-label="Filter by category">
          <button class="search-filters__pill search-filters__pill--active" data-category="all">All</button>
          <button class="search-filters__pill" data-category="Player Profile">Players</button>
          <button class="search-filters__pill" data-category="Farm System">Farm</button>
          <button class="search-filters__pill" data-category="Game Recap">Recaps</button>
          <button class="search-filters__pill" data-category="Stat Explainer">Explainers</button>
          <button class="search-filters__pill" data-category="Fantasy Baseball">Fantasy</button>
          <button class="search-filters__pill" data-category="Rankings">Rankings</button>
        </div>
      </div>

      <div class="search-filters__group">
        <span class="search-filters__label">Level</span>
        <div class="search-filters__pills" id="level-pills" role="group" aria-label="Filter by level">
          <button class="search-filters__pill search-filters__pill--active" data-level="all">All</button>
          <button class="search-filters__pill" data-level="Beginner">Beginner</button>
          <button class="search-filters__pill" data-level="Intermediate">Intermediate</button>
          <button class="search-filters__pill" data-level="Advanced">Advanced</button>
        </div>
      </div>
    </section>

    <ul class="article-list">

      {% for article in articles %}
      <li class="article-card" data-url="{{ article.url }}">
        <div class="article-card__meta">
          <a href="/category/{{ article.frontmatter.category | categorySlug }}" class="article-card__category">{{ article.frontmatter.category }}</a>
          {% if article.frontmatter.level %}<span class="article-header__level article-header__level--{{ article.frontmatter.level | lower }}">{{ article.frontmatter.level }}</span>{% endif %}
          <time datetime="{{ article.frontmatter.date | dateYearMonth }}">{{ article.frontmatter.date | dateDisplay }}</time>
        </div>
        <h2 class="article-card__title">
          <a href="{{ article.url }}">{{ article.frontmatter.title }}</a>
        </h2>
        <p class="article-card__excerpt">{{ article.frontmatter.description }}</p>
        <a href="{{ article.url }}" class="article-card__readmore">Read article &rarr;</a>
      </li>
      {% endfor %}

      <li class="article-list__empty" id="no-results" hidden>
        No articles match your filters.
        <button class="article-list__clear" id="clear-filters">Clear all filters</button>
      </li>

    </ul>

    <script type="application/json" id="article-search-data">
    [
      {% for article in articles %}
      {
        "url": {{ article.url | json }},
        "title": {{ article.frontmatter.title | json }},
        "description": {{ article.frontmatter.description | json }},
        "category": {{ article.frontmatter.category | json }},
        "level": {{ (article.frontmatter.level or "") | json }},
        "keywords": {{ (article.frontmatter.keywords or []) | json }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
    </script>

  </main>

  <script src="/js/search.js"></script>
{% endblock %}
