---
layout: base.njk
title: ""
description: "Advanced stats. Beginner friendly."
permalink: /index.html
---
  <main class="page">

    <header class="home-header">
      <h1 class="home-header__title">Exit Velo</h1>
      <p class="home-header__description">Advanced stats. Beginner friendly.</p>
    </header>

    <ul class="article-list">

      {% for article in collections.articles %}
      <li class="article-card">
        <div class="article-card__meta">
          <span class="article-card__category">{{ article.data.category }}</span>
          {% if article.data.level %}<span class="article-header__level article-header__level--{{ article.data.level | lower }}">{{ article.data.level }}</span>{% endif %}
          <time datetime="{{ article.data.date | dateYearMonth }}">{{ article.data.date | dateDisplay }}</time>
        </div>
        <h2 class="article-card__title">
          <a href="{{ article.url }}">{{ article.data.title }}</a>
        </h2>
        <p class="article-card__excerpt">{{ article.data.description }}</p>
        <a href="{{ article.url }}" class="article-card__readmore">Read article &rarr;</a>
      </li>
      {% endfor %}

    </ul>

  </main>
