---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Exit Velo</title>
    <link>https://exitvelo.us</link>
    <description>Where baseball stats make sense.</description>
    <language>en-us</language>
    <atom:link href="https://exitvelo.us/feed.xml" rel="self" type="application/rss+xml"/>
    <lastBuildDate>{{ collections.articles[0].date | dateRfc822 }}</lastBuildDate>
{%- for article in collections.articles %}
    <item>
      <title>{{ article.data.title }}</title>
      <link>https://exitvelo.us{{ article.url }}</link>
      <guid isPermaLink="true">https://exitvelo.us{{ article.url }}</guid>
      <pubDate>{{ article.date | dateRfc822 }}</pubDate>
      {% if article.data.category %}<category>{{ article.data.category }}</category>{% endif %}
      <description><![CDATA[{{ article.data.excerpt if article.data.excerpt else article.data.description }}]]></description>
    </item>
{%- endfor %}
  </channel>
</rss>
